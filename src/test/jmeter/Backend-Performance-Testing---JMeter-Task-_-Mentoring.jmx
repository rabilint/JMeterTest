            <JSR223PreProcessor guiclass="TestBeanGUI" testclass="JSR223PreProcessor" testname="JSR223 PreProcessor" enabled="true">
              <stringProp name="cacheKey">true</stringProp>
              <stringProp name="filename"></stringProp>
              <stringProp name="parameters"></stringProp>
              <stringProp name="script">import java.text.DecimalFormat

String tableId = vars.get(&quot;random_table_product_id&quot;);
String tablePriceStr = vars.get(&quot;random_table_product_price&quot;);
String chairId = vars.get(&quot;random_chair_product_id&quot;);
String chairPriceStr = vars.get(&quot;random_chair_product_price&quot;);


boolean isThereChair = &quot;true&quot;.equals(vars.get(&quot;IS_CHAIR_ADDED&quot;));

float totalSum = 0.0;

if(tablePriceStr != null){
    try{
        totalSum += Float.parseFloat(tablePriceStr.replace(&apos;$&apos;, &apos;&apos;).replace(&apos;,&apos;,&apos;&apos;).trim());
    } catch (Exception e) {
        log.error(&quot;Found error in TABLE price parse: &quot; + e.getMessage());
    }
}

if(isThereChair &amp;&amp; chairPriceStr != null){
    try{
        totalSum += Float.parseFloat(chairPriceStr.replace(&apos;$&apos;,&apos;&apos;).replace(&apos;,&apos;,&apos;&apos;).trim());
    } catch (Exception e) {
        log.error(&quot;Found error in CHAIR price parse: &quot; + e.getMessage());
    }
}

DecimalFormat df = new DecimalFormat(&quot;0.00&quot;);
String totalPrice = df.format(totalSum).replace(&quot;,&quot;, &quot;.&quot;);

var req = sampler; 

req.addArgument(&quot;p_id[]&quot;, tableId + &quot;__&quot;);
req.addArgument(&quot;p_quantity[]&quot;, &quot;1&quot;);

String finalCartContent = &quot;{\&quot;&quot; + tableId + &quot;__\&quot;:1&quot;;

if(isThereChair){
    req.addArgument(&quot;p_id[]&quot;, chairId + &quot;__&quot;);
    req.addArgument(&quot;p_quantity[]&quot;, &quot;1&quot;);
    
    finalCartContent = finalCartContent + &quot;,\&quot;&quot; + chairId + &quot;__\&quot;:1}&quot;;
} else {
    finalCartContent = finalCartContent + &quot;}&quot;;
}

vars.put(&quot;calc_cart_content&quot;, finalCartContent);
vars.put(&quot;calc_total_net&quot;, totalPrice);
vars.put(&quot;calc_trans_id&quot;, String.valueOf(System.currentTimeMillis()));
</stringProp>
              <stringProp name="scriptLanguage">groovy</stringProp>
            </JSR223PreProcessor>
